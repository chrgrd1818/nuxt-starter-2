# ============================================================================
# Nuxt App .gitignore — build artifacts and secrets
# ============================================================================

# Nuxt build output
.nuxt/
.output/
dist/

# Dependencies
node_modules/

# Environment files
.env
.env.*
!.env.example

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/

# Misc
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
